# PostgreSQL 配置
POSTGRES_HOST=172.20.48.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_db

# JWT 配置
JWT_SECRET_KEY=a7f3e9d2c1b8a4f6e5d7c9b3a1f2e4d6c8b0a2f4e6d8c0a2f4e6d8c0a2f4e6d8
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# 意图路由配置
INTENT_ROUTER_USE_LLM=true
INTENT_ROUTER_CACHE_SIZE=100

# serpapi 网络搜索工具
SERPAPI_API_KEY=

# Embedding 配置 选择使用的模型类型: remote 或 local
ENABLE_STORAGE=true
EMBEDDING_TYPE=remote

# 远程API配置
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# LLM 配置
LLM_TYPE=remote
LLM_MODEL_NAME=qwen3.5-plus-2026-02-15
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# 本地模型名称: bge-small-zh, bge-base-zh, bge-large-zh, m3e-base, text2vec-base
LOCAL_EMBEDDING_MODEL=bge-small-zh

# 本地模型路径（可选，不指定则使用预设路径）
LOCAL_EMBEDDING_PATH=/mnt/e/HF_HOME/hub/models--BAAI--bge-small-zh-v1.5/snapshots/7999e1d3359715c523056ef9478215996d62a620

# ========== 向量存储配置 ==========
VECTOR_STORE_HOST=172.20.48.1
VECTOR_STORE_PORT=19530
VECTOR_STORE_USER=
VECTOR_STORE_PASSWORD=

# 运行设备: cpu 或 cuda
EMBEDDING_DEVICE=cuda

# 批量处理大小
EMBEDDING_BATCH_SIZE=32

# 混合检索权重 向量检索权重和关键词检索权重
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_KEYWORD_WEIGHT=0.4

# 检索参数 Top-K 召回数量和相似度阈值
SIMILARITY_TOP_K=5
SIMILARITY_THRESHOLD=0.3

# rerank auto或remote或local
RERANK_TYPE=remote
RERANK_MODEL=gte-rerank-v2
RERANK_API_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# A2A
A2A_RAG_URL=http://localhost:8001
A2A_DISCOVERY_TIMEOUT=10
A2A_CACHE_TTL=300

# Redis 配置
REDIS_HOST=172.20.48.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SESSION_TTL=604800

# 记忆配置
MEMORY_MAX_TURNS=20
MEMORY_MAX_TOKENS=4000

# ========== 做梦模块配置 ==========
# 实体记忆存储目录
ENTITY_MEMORY_DIR=entity_memory
# 单次做梦最多提炼记忆数
MAX_MEMORIES_PER_DREAM=20
# 保留记忆的最低重要性分数
IMPORTANCE_THRESHOLD=0.4
# 最少未处理会话数才触发做梦
MIN_SESSIONS_FOR_DREAM=1
# 单次处理的最大会话数
MAX_SESSIONS_PER_DREAM=50
# 启动时不做梦
DREAM_ON_STARTUP=false
# 启用后台调度器
ENABLE_DREAM_SCHEDULER=true
# 调度间隔（秒）- 10分钟
DREAM_INTERVAL_SECONDS=600
# 空闲阈值（秒）- 30秒无请求视为空闲
DREAM_IDLE_THRESHOLD_SECONDS=30

# ========== 行业研究配置 ==========
# 行业研究默认搜索模式 (knowledge/web/none)
INDUSTRY_DEFAULT_SEARCH_MODE=knowledge
# 行业研究默认专家模式
INDUSTRY_DEFAULT_EXPERT_MODE=true
# 行业研究检索数量
INDUSTRY_TOP_K=8
# 行业研究召回数量
INDUSTRY_RECALL_K=16
# ========== GraphRAG 配置（知识图谱）==========
GRAPH_RAG_ENABLED=true
GRAPH_CACHE_TTL=3600
ENABLE_GRAPH_CACHE=true
GRAPH_MAX_ENTITIES=100
ENTITY_MIN_FREQUENCY=1
COMMUNITY_MIN_SIZE=2
COMMUNITY_RESOLUTION=1.0